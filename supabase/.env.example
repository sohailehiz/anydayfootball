# Copy this file to .env (same folder) and fill in real values. Never commit .env.
#
# Find both in your Supabase project dashboard: Settings -> API.

# Project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=

# The "service_role" secret key (NOT the anon/public key). This bypasses Row Level Security,
# so it must only ever live in this local .env file and be used by seed.mjs — never in the
# .html files, never committed to git.
SUPABASE_SERVICE_ROLE_KEY=
